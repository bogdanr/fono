# Maintainer: Bogdan Rădulescu <bogdan@nimblex.net>
pkgname=fono
pkgver=0.1.0
pkgrel=1
pkgdesc="Lightweight native voice dictation — press a hotkey, speak, text appears"
arch=('x86_64' 'aarch64')
url="https://github.com/bogdanr/fono"
license=('GPL-3.0-only')
depends=('gcc-libs')
optdepends=(
  'libappindicator-gtk3: system tray icon on X11/XEmbed-based panels'
  'wtype: keystroke injection on wlroots Wayland compositors'
  'ydotool: keystroke injection on GNOME/KDE Wayland'
  'xdotool: keystroke injection fallback on X11'
  'pipewire: recommended audio stack (also works with pulseaudio/alsa)'
)
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --frozen --profile release-slim -p fono
}

check() {
  cd "$pkgname-$pkgver"
  cargo test --frozen --workspace --lib
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 target/release-slim/fono         "$pkgdir/usr/bin/fono"
  install -Dm644 packaging/slackbuild/fono/fono.desktop \
                                                  "$pkgdir/usr/share/applications/fono.desktop"
  install -Dm644 packaging/slackbuild/fono/fono.svg \
                                                  "$pkgdir/usr/share/icons/hicolor/scalable/apps/fono.svg"
  install -Dm644 packaging/systemd/fono.service   "$pkgdir/usr/lib/systemd/user/fono.service"
  install -Dm644 LICENSE                          "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md                        "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 CHANGELOG.md                     "$pkgdir/usr/share/doc/$pkgname/CHANGELOG.md"

  "$pkgdir/usr/bin/fono" completions bash | install -Dm644 /dev/stdin \
    "$pkgdir/usr/share/bash-completion/completions/fono"
  "$pkgdir/usr/bin/fono" completions zsh  | install -Dm644 /dev/stdin \
    "$pkgdir/usr/share/zsh/site-functions/_fono"
  "$pkgdir/usr/bin/fono" completions fish | install -Dm644 /dev/stdin \
    "$pkgdir/usr/share/fish/vendor_completions.d/fono.fish"
}
