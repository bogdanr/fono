# Rust build artifacts
/target/
**/target/
/target-cpu/
/target-gpu/
**/*.rs.bk
Cargo.lock.bak

# Local scratch / large support files (models, prebuilt libs, venv)
/tmp/

# Generated Jekyll site output (docs/ is the source; _site is built)
/_site/

# IDE / editor
.idea/
.vscode/
*.iml
*.swp
*.swo
.DS_Store

# Fono runtime / user state
secrets.toml
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Logs
*.log
# Vim swap/undo files at repo root
.*.un~
*~

# Wake-word training venv (host tooling; never committed)
/.venv-wakeword/

# Local dev-host addresses (FONO_MAC_HOST / FONO_WIN_HOST) — per the
# macOS/Windows port plans' guiding constraint, these never live in
# the repo. Source .env.hosts.local yourself before using
# scripts/mac-remote.sh or scripts/win-remote.sh.
.env.hosts.local

